@page
@model BankLoanManagement.UI.Pages.LoanTypes.IndexModel

<div style="width:90%; margin:auto; font-family:Arial;">

    <div style="display:flex; justify-content:space-between; align-items:center; margin-top:30px; margin-bottom:20px;">
        <h2 style="color:#0d6efd;">Loan Type Management</h2>

        <a asp-page="Create"
           style="background:#198754; color:white; text-decoration:none; padding:10px 15px; border-radius:5px;">
            + Add Loan Type
        </a>
    </div>

    <table style="width:100%; border-collapse:collapse; box-shadow:0 0 10px #ddd;">
        <thead>
            <tr style="background:#0d6efd; color:white;">
                <th style="padding:12px;">Loan Type ID</th>
                <th style="padding:12px;">Loan Name</th>
                <th style="padding:12px;">Interest Rate</th>
                <th style="padding:12px;">Max Amount</th>
                <th style="padding:12px;">Max Tenure</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.LoanTypes)
            {
                <tr style="text-align:center; border-bottom:1px solid #ddd;">
                    <td style="padding:10px;">@item.LoanTypeId</td>
                    <td style="padding:10px;">@item.LoanName</td>
                    <td style="padding:10px;">@item.InterestRate %</td>
                    <td style="padding:10px;">₹ @item.MaxLoanAmount</td>
                    <td style="padding:10px;">@item.MaxTenureMonths months</td>
                </tr>
            }
        </tbody>
    </table>
</div>