@page
@model BankLoanManagement.UI.Pages.Customers.IndexModel

<div style="width:90%; margin:auto; font-family:Arial;">

    <div style="display:flex; justify-content:space-between; align-items:center; margin-top:30px; margin-bottom:20px;">

        <h2 style="color:#0d6efd;">
            Customer Management
        </h2>

        <a asp-page="Create"
           style="background:#198754;
            color:white;
            text-decoration:none;
            padding:10px 15px;
            border-radius:5px;">
            + Add Customer
        </a>

    </div>

    <table style="width:100%;
        border-collapse:collapse;
        box-shadow:0 0 10px #ddd;">

        <thead>

            <tr style="background:#0d6efd; color:white;">

                <th style="padding:12px;">Customer ID</th>
                <th style="padding:12px;">Full Name</th>
                <th style="padding:12px;">Email</th>
                <th style="padding:12px;">Mobile</th>
                <th style="padding:12px;">Income</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model.Customers)
            {
                <tr style="text-align:center;
                    border-bottom:1px solid #ddd;">

                    <td style="padding:10px;">
                        @item.CustomerId
                    </td>

                    <td style="padding:10px;">
                        @item.FullName
                    </td>

                    <td style="padding:10px;">
                        @item.Email
                    </td>

                    <td style="padding:10px;">
                        @item.MobileNumber
                    </td>

                    <td style="padding:10px;">
                        ₹ @item.AnnualIncome
                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>