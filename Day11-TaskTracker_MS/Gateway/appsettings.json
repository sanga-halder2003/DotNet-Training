{
  "ReverseProxy": {
    "Routes": {
      "taskRoute": {
        "ClusterId": "taskCluster",
        "Match": {
          "Path": "/api/tasks/{**catch-all}"
        }
      },
      "userRoute": {
        "ClusterId": "userCluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "taskCluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7249/"
          }
        }
      },
      "userCluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7200/"
          }
        }
      }
    }
  }
}